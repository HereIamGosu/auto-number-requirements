{
  "name": "auto-number-requirements",
  "displayName": "Auto-Number Requirements",
  "description": "Автоматическая нумерация требований FR и NFR в спецификациях",
  "version": "1.0.4",
  "publisher": "hereiamgosu",
  "repository": {
    "type": "git",
    "url": "https://github.com/HereIamGosu/auto-number-requirements.git"
  },
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "auto-number-requirements.numberRequirements",
        "title": "Auto-number Requirements (FR/NFR)"
      }
    ],
    "keybindings": [
      {
        "command": "auto-number-requirements.numberRequirements",
        "key": "ctrl+alt+n",
        "mac": "cmd+alt+n",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "Auto-number Requirements",
      "properties": {
        "auto-number-requirements.requirementTypes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "FR",
            "NFR"
          ],
          "description": "Список типов требований для нумерации. Каждый тип нумеруется независимо."
        },
        "auto-number-requirements.startFrom": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "description": "Начальный номер при нумерации требований."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "mocha"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/vscode": "^1.80.0",
    "@vscode/test-electron": "^2.5.2",
    "mocha": "^11.7.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}
